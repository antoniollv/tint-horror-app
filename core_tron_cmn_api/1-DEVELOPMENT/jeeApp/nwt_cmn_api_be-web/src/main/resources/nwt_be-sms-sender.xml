<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.1.xsd">

	 <!--  Envio de SMS -->
   <bean id="EnviarMensaje" parent="wsProxy">
		<property name="serviceInterface"
			value="com.mapfre.mutua.plataformasms.webservices.control.EnviarMensaje" />
		<property name="wsdlDocumentUrl" value="classpath:/META-INF/wsdl/EnviarMensaje.wsdl" />
		<property name="namespaceUri"
			value="http://control.webServices.plataformasms.mutua.mapfre.com" />
		<property name="serviceName" value="EnviarMensajeService" />
		<property name="portName" value="EnviarMensaje" />
		<property name="username" value="${app.sms.username}" />
		<property name="password" value="${app.sms.password}" />
		<property name="endPointResolver" ref="EnviarMensajeServiceEndPointResolverRegistry" />
	</bean>

	<bean id="EnviarMensajeServiceEndPointResolverRegistry" parent="baseWsrrEndPointResolverNonCache">
		<property name="wsdlId" value="EnviarMensaje.wsdl"></property>
		<property name="version" value="1.0"></property>
		<property name="resolveLocal" value="false" />
	</bean>
    
	
</beans>