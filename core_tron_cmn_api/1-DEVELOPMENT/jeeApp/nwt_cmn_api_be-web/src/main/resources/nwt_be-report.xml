<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.1.xsd">

  <bean id="Reporter" parent="wsProxy">
    <property name="serviceInterface" value="com.mapsoft.wtw.reports.Reporter" />
    <property name="wsdlDocumentUrl" value="classpath:/META-INF/wsdl/Reporter.wsdl" />
    <property name="serviceName" value="ReporterService" />
    <property name="portName" value="Reporter" />
    <property name="namespaceUri" value="http://reports.wtw.mapsoft.com" />
    <property name="endPointResolver" ref="nwtEndPointResolver" />
  </bean>

  <bean id="nwtEndPointResolver" class="com.mapfre.nwt.wsrr.NwtReportEndPointResolver">
    <!-- <property name="serviceVbles" value="com.mapfre.nwt.trn.sr.SrReportEndPointResolver"/>  -->
  </bean>
  
</beans>